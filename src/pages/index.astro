---
import Base from '../layouts/Base.astro';
---

<Base
  title="Roosted — Backyard Chicken Guides & Coop Plans"
  description="Expert backyard chicken guides, breed profiles, care tips, and premium downloadable coop plans. Everything your flock needs, written by real chicken keepers."
>

  <!-- =====================================================================
       HERO
       ===================================================================== -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden">
    <!-- Layered gradient background — golden hour warmth -->
    <div class="absolute inset-0" style="
      background:
        radial-gradient(ellipse at 10% 80%, oklch(0.74 0.13 58 / 0.18), transparent 55%),
        radial-gradient(ellipse at 85% 15%, oklch(0.74 0.13 58 / 0.10), transparent 50%),
        radial-gradient(ellipse at 60% 90%, oklch(0.44 0.12 155 / 0.06), transparent 45%),
        linear-gradient(to bottom, oklch(0.99 0.006 85), oklch(0.96 0.012 80));
    "></div>

    <!-- Subtle grain texture overlay -->
    <div class="absolute inset-0 opacity-[0.025]" style="background-image: url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22300%22 height=%22300%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22300%22 height=%22300%22 filter=%22url(%23noise)%22 opacity=%221%22/%3E%3C/svg%3E');"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <!-- Eyebrow -->
        <p class="inline-flex items-center gap-2 text-sm font-semibold text-brand-600 tracking-widest uppercase mb-6 animate-fade-in" style="font-family: var(--font-body);">
          <span class="w-6 h-px bg-brand-500 inline-block"></span>
          Backyard Chicken Keeping Made Simple
        </p>

        <!-- Headline -->
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black tracking-tight text-surface-900 leading-[1.05] animate-slide-up" style="font-family: var(--font-display);">
          Raise happy chickens.<br>
          <em class="not-italic text-brand-500">Build the perfect coop.</em>
        </h1>

        <!-- Subheadline -->
        <p class="mt-6 text-lg md:text-xl text-surface-800/60 max-w-xl leading-relaxed animate-slide-up delay-100" style="font-family: var(--font-body);">
          From choosing your first breeds to building a coop your neighbors will envy — expert guides and downloadable plans written by people who actually keep chickens.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-col sm:flex-row gap-4 animate-slide-up delay-200">
          <a
            href="/blog"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-brand-500 text-white font-semibold rounded-xl hover:bg-brand-600 transition-colors text-base shadow-sm"
            style="font-family: var(--font-body);"
          >
            Browse Free Guides
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
            </svg>
          </a>
          <a
            href="#coop-plans"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-surface-200 text-surface-800 font-semibold rounded-xl hover:border-brand-400 hover:text-brand-600 transition-colors text-base"
            style="font-family: var(--font-body);"
          >
            View Coop Plans
          </a>
        </div>

        <p class="mt-4 text-sm text-surface-800/40 animate-slide-up delay-300" style="font-family: var(--font-body);">
          Free guides, no signup required. Instant PDF download on coop plans.
        </p>
      </div>
    </div>

    <!-- Decorative egg/feather SVG illustration -->
    <div class="absolute right-0 top-1/2 -translate-y-1/2 w-[45%] max-w-lg hidden lg:block opacity-90 animate-fade-in delay-300">
      <svg viewBox="0 0 480 520" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
        <!-- Coop silhouette, abstract geometric -->
        <rect x="80" y="200" width="320" height="220" rx="8" fill="oklch(0.64 0.16 52 / 0.08)" />
        <polygon points="80,200 240,80 400,200" fill="oklch(0.64 0.16 52 / 0.12)" />
        <!-- Door -->
        <rect x="190" y="310" width="100" height="110" rx="50 50 4 4" fill="oklch(0.64 0.16 52 / 0.18)" />
        <!-- Windows -->
        <rect x="110" y="240" width="80" height="60" rx="6" fill="oklch(0.74 0.13 58 / 0.20)" />
        <rect x="290" y="240" width="80" height="60" rx="6" fill="oklch(0.74 0.13 58 / 0.20)" />
        <!-- Perch lines -->
        <line x1="100" y1="300" x2="380" y2="300" stroke="oklch(0.64 0.16 52 / 0.15)" stroke-width="3"/>
        <!-- Ground -->
        <ellipse cx="240" cy="430" rx="200" ry="18" fill="oklch(0.44 0.12 155 / 0.08)" />
        <!-- Sun / egg shape -->
        <ellipse cx="380" cy="100" rx="55" ry="65" fill="oklch(0.87 0.08 68 / 0.40)" />
        <ellipse cx="380" cy="100" rx="38" ry="46" fill="oklch(0.74 0.13 58 / 0.35)" />
        <!-- Feather 1 -->
        <path d="M60 160 Q80 130 100 160 Q80 175 60 160Z" fill="oklch(0.64 0.16 52 / 0.20)" />
        <path d="M55 170 Q75 140 95 170 Q75 185 55 170Z" fill="oklch(0.64 0.16 52 / 0.14)" />
        <!-- Feather 2 -->
        <path d="M400 380 Q420 355 440 380 Q420 393 400 380Z" fill="oklch(0.44 0.12 155 / 0.18)" />
        <path d="M396 390 Q416 365 436 390 Q416 403 396 390Z" fill="oklch(0.44 0.12 155 / 0.12)" />
      </svg>
    </div>
  </section>


  <!-- =====================================================================
       STATS BAR
       ===================================================================== -->
  <section class="py-10 border-y border-surface-200 bg-surface-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { number: "200+", label: "Free guides & articles" },
          { number: "40+",  label: "Downloadable coop plans" },
          { number: "50+",  label: "Breed profiles" },
          { number: "12k+", label: "Backyard flock keepers helped" },
        ].map((stat) => (
          <div>
            <p class="text-3xl font-black tabular-nums text-surface-900 tracking-tight" style="font-family: var(--font-display);">{stat.number}</p>
            <p class="mt-1 text-sm text-surface-800/50" style="font-family: var(--font-body);">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- =====================================================================
       FEATURES GRID
       ===================================================================== -->
  <section class="py-20 md:py-28 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section header -->
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-brand-500 tracking-widest uppercase mb-3" style="font-family: var(--font-body);">What you'll find here</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-surface-900" style="font-family: var(--font-display);">
          Everything a backyard keeper needs
        </h2>
        <p class="mt-4 text-lg text-surface-800/55 leading-relaxed" style="font-family: var(--font-body);">
          Whether you're just getting started or you've been keeping chickens for years, Roosted has the guides, plans, and resources to help your flock thrive.
        </p>
      </div>

      <!-- Cards -->
      <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Card 1 -->
        <div class="group relative bg-white rounded-2xl p-8 border border-surface-200 hover:border-brand-200 hover:shadow-sm transition-all animate-slide-up delay-100">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background-color: oklch(0.94 0.04 72);">
            <svg class="w-6 h-6 text-brand-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.966 8.966 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-surface-900 mb-2" style="font-family: var(--font-display);">In-depth Chicken Guides</h3>
          <p class="text-surface-800/55 leading-relaxed text-base" style="font-family: var(--font-body);">
            From setting up your first coop to managing molting season — practical guides written by experienced keepers, not corporate copywriters.
          </p>
          <a href="/blog" class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-brand-500 hover:text-brand-600 transition-colors" style="font-family: var(--font-body);">
            Read all guides
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
            </svg>
          </a>
        </div>

        <!-- Card 2 -->
        <div class="group relative bg-white rounded-2xl p-8 border border-surface-200 hover:border-brand-200 hover:shadow-sm transition-all animate-slide-up delay-200">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background-color: oklch(0.94 0.04 72);">
            <svg class="w-6 h-6 text-brand-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-surface-900 mb-2" style="font-family: var(--font-display);">Premium Coop Plans</h3>
          <p class="text-surface-800/55 leading-relaxed text-base" style="font-family: var(--font-body);">
            Architect-quality PDF plans with cut lists, materials lists, and step-by-step instructions. Sizes from 2-bird starter coops to 20-bird flock houses.
          </p>
          <a href="#coop-plans" class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-brand-500 hover:text-brand-600 transition-colors" style="font-family: var(--font-body);">
            View coop plans
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
            </svg>
          </a>
        </div>

        <!-- Card 3 -->
        <div class="group relative bg-white rounded-2xl p-8 border border-surface-200 hover:border-brand-200 hover:shadow-sm transition-all animate-slide-up delay-300">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background-color: oklch(0.94 0.04 72);">
            <svg class="w-6 h-6 text-brand-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-surface-900 mb-2" style="font-family: var(--font-display);">Breed Profiles & Care Tips</h3>
          <p class="text-surface-800/55 leading-relaxed text-base" style="font-family: var(--font-body);">
            Detailed profiles for 50+ breeds — temperament, egg production, cold hardiness, and which breeds are best for beginners, small yards, or families with kids.
          </p>
          <a href="/blog" class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-brand-500 hover:text-brand-600 transition-colors" style="font-family: var(--font-body);">
            Explore breeds
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- =====================================================================
       HOW IT WORKS
       ===================================================================== -->
  <section class="py-20 md:py-28 bg-surface-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="text-sm font-semibold text-brand-500 tracking-widest uppercase mb-3" style="font-family: var(--font-body);">Getting started</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-surface-900" style="font-family: var(--font-display);">
          From curious to confident keeper
        </h2>
        <p class="mt-4 text-lg text-surface-800/55 leading-relaxed" style="font-family: var(--font-body);">
          Most people who want backyard chickens don't know where to start. Here's the path we recommend.
        </p>
      </div>

      <div class="relative grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Connecting line (desktop) -->
        <div class="hidden md:block absolute top-8 left-[calc(16.67%+1rem)] right-[calc(16.67%+1rem)] h-px bg-surface-200" aria-hidden="true"></div>

        {[
          {
            step: "01",
            title: "Choose your breed",
            body: "Browse our breed profiles to find chickens that fit your space, climate, and goals — whether you want daily eggs, friendly pets, or both.",
            link: "/blog",
            cta: "Explore breeds →"
          },
          {
            step: "02",
            title: "Plan your coop",
            body: "Download a coop plan sized to your flock. Each plan includes a full materials list, cut list, and clear instructions — no guesswork.",
            link: "#coop-plans",
            cta: "Browse plans →"
          },
          {
            step: "03",
            title: "Keep them thriving",
            body: "Our care guides cover feeding, health, egg laying, molting, and every season so your flock stays healthy all year round.",
            link: "/blog",
            cta: "Read guides →"
          },
        ].map((item) => (
          <div class="relative bg-white rounded-2xl p-8 border border-surface-200">
            <span class="text-5xl font-black text-surface-200 leading-none select-none" style="font-family: var(--font-display);">{item.step}</span>
            <h3 class="mt-3 text-xl font-bold text-surface-900" style="font-family: var(--font-display);">{item.title}</h3>
            <p class="mt-3 text-surface-800/55 leading-relaxed text-base" style="font-family: var(--font-body);">{item.body}</p>
            <a href={item.link} class="mt-5 inline-block text-sm font-semibold text-brand-500 hover:text-brand-600 transition-colors" style="font-family: var(--font-body);">{item.cta}</a>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- =====================================================================
       FEATURE SHOWCASE — Coop Plans
       ===================================================================== -->
  <section id="coop-plans" class="py-20 md:py-28 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Row 1: Text left, visual right -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <p class="text-sm font-semibold text-brand-500 tracking-widest uppercase mb-3" style="font-family: var(--font-body);">Coop plans</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-surface-900" style="font-family: var(--font-display);">
            Plans your neighbor will ask about
          </h2>
          <p class="mt-5 text-lg text-surface-800/55 leading-relaxed" style="font-family: var(--font-body);">
            Our coop plans are drawn to proper architectural standards — not rough sketches. Every plan includes exact dimensions, a full materials and cut list, and step-by-step construction notes you can hand to any contractor or follow yourself.
          </p>
          <ul class="mt-6 space-y-3" style="font-family: var(--font-body);">
            {[
              "Instant PDF download — no waiting, no shipping",
              "Sizes from 2 to 20+ birds",
              "Designed for backyard lots, not farms",
              "Ventilation, predator-proofing, and clean-out access built in",
            ].map((item) => (
              <li class="flex items-start gap-3 text-surface-800/70 text-base">
                <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <a
              href="/blog"
              class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-brand-500 text-white font-semibold rounded-xl hover:bg-brand-600 transition-colors text-base"
              style="font-family: var(--font-body);"
            >
              Browse All Plans
            </a>
          </div>
        </div>

        <!-- Visual: Blueprint-style card -->
        <div class="relative">
          <div class="rounded-2xl overflow-hidden border border-surface-200 shadow-sm" style="background: oklch(0.18 0.015 200 / 1);">
            <div class="p-2 border-b border-white/10 flex items-center gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-white/20"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-white/20"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-white/20"></div>
              <span class="ml-2 text-xs text-white/40 font-mono">roosted-classic-6bird-coop.pdf</span>
            </div>
            <div class="p-8">
              <!-- SVG blueprint sketch -->
              <svg viewBox="0 0 400 320" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
                <!-- Grid lines -->
                <defs>
                  <pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
                    <path d="M 20 0 L 0 0 0 20" fill="none" stroke="oklch(0.74 0.13 58 / 0.08)" stroke-width="0.5"/>
                  </pattern>
                </defs>
                <rect width="400" height="320" fill="url(#grid)" />

                <!-- Front elevation -->
                <rect x="40" y="120" width="200" height="140" stroke="oklch(0.74 0.13 58 / 0.7)" stroke-width="1.5" fill="none" />
                <polygon points="40,120 140,50 240,120" stroke="oklch(0.74 0.13 58 / 0.7)" stroke-width="1.5" fill="none"/>
                <!-- Door -->
                <rect x="95" y="190" width="50" height="70" rx="25 25 2 2" stroke="oklch(0.74 0.13 58 / 0.5)" stroke-width="1" fill="none"/>
                <!-- Windows -->
                <rect x="52" y="140" width="35" height="35" rx="3" stroke="oklch(0.74 0.13 58 / 0.5)" stroke-width="1" fill="none"/>
                <line x1="69.5" y1="140" x2="69.5" y2="175" stroke="oklch(0.74 0.13 58 / 0.3)" stroke-width="0.8"/>
                <line x1="52" y1="157.5" x2="87" y2="157.5" stroke="oklch(0.74 0.13 58 / 0.3)" stroke-width="0.8"/>
                <rect x="193" y="140" width="35" height="35" rx="3" stroke="oklch(0.74 0.13 58 / 0.5)" stroke-width="1" fill="none"/>
                <line x1="210.5" y1="140" x2="210.5" y2="175" stroke="oklch(0.74 0.13 58 / 0.3)" stroke-width="0.8"/>
                <line x1="193" y1="157.5" x2="228" y2="157.5" stroke="oklch(0.74 0.13 58 / 0.3)" stroke-width="0.8"/>

                <!-- Dimension lines -->
                <line x1="40" y1="272" x2="240" y2="272" stroke="oklch(0.74 0.13 58 / 0.35)" stroke-width="1" marker-start="url(#arrow)" marker-end="url(#arrow)"/>
                <text x="140" y="285" text-anchor="middle" fill="oklch(0.74 0.13 58 / 0.6)" font-size="9" font-family="monospace">8'-0"</text>
                <line x1="255" y1="120" x2="255" y2="260" stroke="oklch(0.74 0.13 58 / 0.35)" stroke-width="1"/>
                <text x="268" y="195" fill="oklch(0.74 0.13 58 / 0.6)" font-size="9" font-family="monospace">6'-0"</text>

                <!-- Side elevation label -->
                <text x="290" y="50" fill="oklch(0.74 0.13 58 / 0.5)" font-size="10" font-family="monospace">SIDE ELEVATION</text>
                <rect x="290" y="80" width="100" height="90" stroke="oklch(0.74 0.13 58 / 0.5)" stroke-width="1" fill="none"/>
                <polygon points="290,80 340,45 390,80" stroke="oklch(0.74 0.13 58 / 0.5)" stroke-width="1" fill="none"/>

                <!-- Title block -->
                <rect x="40" y="295" width="200" height="18" stroke="oklch(0.74 0.13 58 / 0.3)" stroke-width="0.8" fill="none"/>
                <text x="48" y="307" fill="oklch(0.74 0.13 58 / 0.5)" font-size="8" font-family="monospace">ROOSTED — CLASSIC 6-BIRD COOP — SHEET 1 OF 4</text>
              </svg>
            </div>
          </div>
          <!-- Floating badge -->
          <div class="absolute -top-4 -right-4 bg-brand-500 text-white text-sm font-bold px-4 py-2 rounded-full shadow-md" style="font-family: var(--font-body);">
            Instant PDF
          </div>
        </div>
      </div>

      <!-- Divider -->
      <hr class="divider-feather my-20" />

      <!-- Row 2: Visual left, text right -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
